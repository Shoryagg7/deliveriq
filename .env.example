# DeliverIQ — environment template (safe to commit).
# Copy to .env and fill in real values:  cp .env.example .env
# .env itself is gitignored (holds secrets) — never commit it.

# --- Required ---
# PostgreSQL connection (no default — the app fails fast if unset).
DATABASE_URL=postgresql://deliveriq_user:password@localhost:5432/deliveriq_db

# --- Optional (defaults live in app/core/config.py) ---
REDIS_URL=redis://localhost:6379/0

# Token-bucket rate limiter (Day 16 / hardened Day 25).
# Set RATE_LIMIT_ENABLED=false to disable it for load tests.
RATE_LIMIT_ENABLED=true
RATE_LIMIT_CAPACITY=100
RATE_LIMIT_REFILL_PER_MIN=100
